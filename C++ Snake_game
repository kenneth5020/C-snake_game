#include <ncurses.h>
#include <deque>
#include <vector>
#include <cstdlib>
#include <ctime>
using namespace std;

#define HEIGHT 21
#define WIDTH 21
#define STAGE_COUNT 4

// 0 empty, 1 wall, 2 immune wall, 3 head, 4 body, 5 growth, 6 poison, 7 gate
int mapData[HEIGHT][WIDTH];

struct Pos {
    int y, x;
};

deque<Pos> snake;

int dirY = 0, dirX = 1;
bool gameOver = false;
bool clearStage = false;

int stage = 1;
int growthCount = 0;
int poisonCount = 0;
int gateCount = 0;
int maxLength = 3;
int gameTime = 0;
int tickCount = 0;

int itemTimer = 0;
int gateTimer = 0;

Pos gateA, gateB;
bool gateActive = false;

int missionB[STAGE_COUNT] = {5, 6, 7, 8};
int missionGrowth[STAGE_COUNT] = {1, 2, 2, 3};
int missionPoison[STAGE_COUNT] = {0, 1, 1, 2};
int missionGate[STAGE_COUNT] = {1, 1, 2, 2};

void resetScore() {
    growthCount = 0;
    poisonCount = 0;
    gateCount = 0;
    maxLength = 3;
    gameTime = 0;
    tickCount = 0;
    itemTimer = 0;
    gateTimer = 0;
    gateActive = false;
}

void makeBaseMap() {
    for (int y = 0; y < HEIGHT; y++) {
        for (int x = 0; x < WIDTH; x++) {
            if ((y == 0 && x == 0) ||
                (y == 0 && x == WIDTH - 1) ||
                (y == HEIGHT - 1 && x == 0) ||
                (y == HEIGHT - 1 && x == WIDTH - 1)) {
                mapData[y][x] = 2;
            }
            else if (y == 0 || y == HEIGHT - 1 || x == 0 || x == WIDTH - 1) {
                mapData[y][x] = 1;
            }
            else {
                mapData[y][x] = 0;
            }
        }
    }
}

void makeStageWall() {
    if (stage == 1) {
        for (int x = 5; x <= 15; x++) mapData[5][x] = 1;
    }
    else if (stage == 2) {
        for (int y = 4; y <= 15; y++) mapData[y][5] = 1;
        for (int x = 10; x <= 16; x++) mapData[14][x] = 1;
    }
    else if (stage == 3) {
        for (int x = 3; x <= 17; x++) mapData[7][x] = 1;
        for (int x = 3; x <= 17; x++) mapData[13][x] = 1;
        mapData[7][10] = 0;
        mapData[13][10] = 0;
    }
    else if (stage == 4) {
        for (int y = 3; y <= 17; y++) mapData[y][6] = 1;
        for (int y = 3; y <= 17; y++) mapData[y][14] = 1;
        for (int x = 6; x <= 14; x++) mapData[10][x] = 1;
        mapData[10][10] = 0;
    }
}

void initSnake() {
    snake.clear();
    snake.push_back({10, 10});
    snake.push_back({10, 9});
    snake.push_back({10, 8});
    dirY = 0;
    dirX = 1;
}

void initStage() {
    makeBaseMap();
    makeStageWall();
    initSnake();
}

void updateSnakeOnMap() {
    for (int y = 1; y < HEIGHT - 1; y++) {
        for (int x = 1; x < WIDTH - 1; x++) {
            if (mapData[y][x] == 3 || mapData[y][x] == 4) {
                mapData[y][x] = 0;
            }
        }
    }

    for (int i = 0; i < snake.size(); i++) {
        int y = snake[i].y;
        int x = snake[i].x;

        if (i == 0) mapData[y][x] = 3;
        else mapData[y][x] = 4;
    }

    if (gateActive) {
        mapData[gateA.y][gateA.x] = 7;
        mapData[gateB.y][gateB.x] = 7;
    }
}

void removeItems() {
    for (int y = 1; y < HEIGHT - 1; y++) {
        for (int x = 1; x < WIDTH - 1; x++) {
            if (mapData[y][x] == 5 || mapData[y][x] == 6) {
                mapData[y][x] = 0;
            }
        }
    }
}

void createOneItem(int type) {
    while (true) {
        int y = rand() % (HEIGHT - 2) + 1;
        int x = rand() % (WIDTH - 2) + 1;

        if (mapData[y][x] == 0) {
            mapData[y][x] = type;
            break;
        }
    }
}

void createItems() {
    removeItems();
    createOneItem(5);
    createOneItem(5);
    createOneItem(6);
    itemTimer = 0;
}

void updateItems() {
    itemTimer++;
    if (itemTimer >= 10) {
        createItems();
    }
}

void removeGates() {
    if (gateActive) {
        mapData[gateA.y][gateA.x] = 1;
        mapData[gateB.y][gateB.x] = 1;
        gateActive = false;
    }
}

void createGates() {
    removeGates();

    vector<Pos> walls;
    for (int y = 0; y < HEIGHT; y++) {
        for (int x = 0; x < WIDTH; x++) {
            if (mapData[y][x] == 1) {
                walls.push_back({y, x});
            }
        }
    }

    if (walls.size() < 2) return;

    int a = rand() % walls.size();
    int b = rand() % walls.size();

    while (a == b) {
        b = rand() % walls.size();
    }

    gateA = walls[a];
    gateB = walls[b];

    mapData[gateA.y][gateA.x] = 7;
    mapData[gateB.y][gateB.x] = 7;
    gateActive = true;
    gateTimer = 0;
}

void updateGates() {
    gateTimer++;
    if (gateTimer >= 20) {
        createGates();
    }
}

Pos getOtherGate(Pos p) {
    if (p.y == gateA.y && p.x == gateA.x) return gateB;
    return gateA;
}

bool canGo(int y, int x) {
    if (y < 0 || y >= HEIGHT || x < 0 || x >= WIDTH) return false;
    return mapData[y][x] == 0 || mapData[y][x] == 5 || mapData[y][x] == 6;
}

void setExitDirection(Pos g) {
    if (g.y == 0) {
        dirY = 1; dirX = 0;
    }
    else if (g.y == HEIGHT - 1) {
        dirY = -1; dirX = 0;
    }
    else if (g.x == 0) {
        dirY = 0; dirX = 1;
    }
    else if (g.x == WIDTH - 1) {
        dirY = 0; dirX = -1;
    }
    else {
        int dy[4] = {dirY, dirX, -dirX, -dirY};
        int dx[4] = {dirX, -dirY, dirY, -dirX};

        for (int i = 0; i < 4; i++) {
            int ny = g.y + dy[i];
            int nx = g.x + dx[i];

            if (canGo(ny, nx)) {
                dirY = dy[i];
                dirX = dx[i];
                return;
            }
        }

        gameOver = true;
    }
}

bool missionComplete() {
    int idx = stage - 1;

    return maxLength >= missionB[idx] &&
           growthCount >= missionGrowth[idx] &&
           poisonCount >= missionPoison[idx] &&
           gateCount >= missionGate[idx];
}

void drawMap() {
    clear();

    for (int y = 0; y < HEIGHT; y++) {
        for (int x = 0; x < WIDTH; x++) {
            if (mapData[y][x] == 0) mvprintw(y, x, " ");
            else if (mapData[y][x] == 1) mvprintw(y, x, "#");
            else if (mapData[y][x] == 2) mvprintw(y, x, "X");
            else if (mapData[y][x] == 3) mvprintw(y, x, "@");
            else if (mapData[y][x] == 4) mvprintw(y, x, "o");
            else if (mapData[y][x] == 5) mvprintw(y, x, "+");
            else if (mapData[y][x] == 6) mvprintw(y, x, "-");
            else if (mapData[y][x] == 7) mvprintw(y, x, "G");
        }
    }

    int idx = stage - 1;

    mvprintw(1, WIDTH + 4, "Stage %d", stage);

    mvprintw(3, WIDTH + 4, "Score Board");
    mvprintw(4, WIDTH + 4, "B: %d / %d", (int)snake.size(), maxLength);
    mvprintw(5, WIDTH + 4, "+: %d", growthCount);
    mvprintw(6, WIDTH + 4, "-: %d", poisonCount);
    mvprintw(7, WIDTH + 4, "G: %d", gateCount);
    mvprintw(8, WIDTH + 4, "Time: %d", gameTime);

    mvprintw(11, WIDTH + 4, "Mission");
    mvprintw(12, WIDTH + 4, "B: %d [%c]", missionB[idx], maxLength >= missionB[idx] ? 'v' : ' ');
    mvprintw(13, WIDTH + 4, "+: %d [%c]", missionGrowth[idx], growthCount >= missionGrowth[idx] ? 'v' : ' ');
    mvprintw(14, WIDTH + 4, "-: %d [%c]", missionPoison[idx], poisonCount >= missionPoison[idx] ? 'v' : ' ');
    mvprintw(15, WIDTH + 4, "G: %d [%c]", missionGate[idx], gateCount >= missionGate[idx] ? 'v' : ' ');

    mvprintw(23, 0, "Arrow keys: move | q: quit");
    refresh();
}

void handleInput() {
    int key = getch();

    if (key == 'q') {
        gameOver = true;
    }
    else if (key == KEY_UP) {
        if (dirY == 1 && dirX == 0) gameOver = true;
        else {
            dirY = -1;
            dirX = 0;
        }
    }
    else if (key == KEY_DOWN) {
        if (dirY == -1 && dirX == 0) gameOver = true;
        else {
            dirY = 1;
            dirX = 0;
        }
    }
    else if (key == KEY_LEFT) {
        if (dirY == 0 && dirX == 1) gameOver = true;
        else {
            dirY = 0;
            dirX = -1;
        }
    }
    else if (key == KEY_RIGHT) {
        if (dirY == 0 && dirX == -1) gameOver = true;
        else {
            dirY = 0;
            dirX = 1;
        }
    }
}

void moveSnake() {
    Pos head = snake.front();

    Pos newHead;
    newHead.y = head.y + dirY;
    newHead.x = head.x + dirX;

    int nextCell = mapData[newHead.y][newHead.x];

    if (nextCell == 1 || nextCell == 2 || nextCell == 4) {
        gameOver = true;
        return;
    }

    bool growth = false;
    bool poison = false;

    if (nextCell == 5) {
        growth = true;
        growthCount++;
    }
    else if (nextCell == 6) {
        poison = true;
        poisonCount++;
    }
    else if (nextCell == 7) {
        gateCount++;

        Pos outGate = getOtherGate(newHead);
        setExitDirection(outGate);

        newHead.y = outGate.y + dirY;
        newHead.x = outGate.x + dirX;

        int exitCell = mapData[newHead.y][newHead.x];

        if (exitCell == 1 || exitCell == 2 || exitCell == 4 || exitCell == 7) {
            gameOver = true;
            return;
        }

        if (exitCell == 5) {
            growth = true;
            growthCount++;
        }
        else if (exitCell == 6) {
            poison = true;
            poisonCount++;
        }
    }

    snake.push_front(newHead);

    if (growth) {
        // 길이 증가: 꼬리 유지
    }
    else if (poison) {
        snake.pop_back();
        snake.pop_back();

        if (snake.size() < 3) {
            gameOver = true;
            return;
        }
    }
    else {
        snake.pop_back();
    }

    if ((int)snake.size() > maxLength) {
        maxLength = snake.size();
    }

    updateSnakeOnMap();

    if (missionComplete()) {
        clearStage = true;
    }
}

void nextStage() {
    stage++;

    if (stage > STAGE_COUNT) {
        gameOver = true;
        return;
    }

    clearStage = false;
    resetScore();
    initStage();
    updateSnakeOnMap();
    createItems();
    createGates();
}

int main() {
    srand(time(0));

    initscr();
    noecho();
    curs_set(0);
    keypad(stdscr, TRUE);
    nodelay(stdscr, TRUE);

    resetScore();
    initStage();
    updateSnakeOnMap();
    createItems();
    createGates();

    while (!gameOver) {
        handleInput();
        moveSnake();
        updateItems();
        updateGates();

        tickCount++;
        if (tickCount % 2 == 0) gameTime++;

        drawMap();

        if (clearStage) {
            nodelay(stdscr, FALSE);
            mvprintw(25, 0, "Stage Clear! Press any key to next stage.");
            getch();
            nodelay(stdscr, TRUE);
            nextStage();
        }

        napms(500);
    }

    nodelay(stdscr, FALSE);

    if (stage > STAGE_COUNT) {
        mvprintw(25, 0, "All Stages Clear! Press any key to exit.");
    }
    else {
        mvprintw(25, 0, "Game Over! Press any key to exit.");
    }

    getch();
    endwin();

    return 0;
}
